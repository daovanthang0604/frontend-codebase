{
  "name": "@workspace/theme",
  "version": "1.0.7",
  "description": "Theme package for Workspace applications",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./postcss.config": "./postcss.config.mjs",
    "./globals.css": "./src/styles/globals.css",
    "./generated.css": "./src/styles/generated.css",
    "./themes.css": "./src/styles/themes.css",
    "./semantic.css": "./src/styles/semantic.css",
    "./provider": "./src/provider.ts"
  },
  "scripts": {
    "gen:css": "tsx scripts/generate-default-theme-css.ts",
