    "@radix-ui/colors": "catalog:",
    "bezier-easing": "catalog:",
    "colorjs.io": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@turbo/gen": "^2.5.5",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
