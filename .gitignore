.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage
test-results/
playwright-report/
blob-report/

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist


# Debug
npm-debug.log*

# Storybook
storybook-static

